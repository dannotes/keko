{
  "manifest_version": 3,
  "name": "KeKo - Keka Auto Check-in/out",
  "version": "1.0.0",
  "description": "Automated check-in and check-out for Keka attendance with customizable schedules",

  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "notifications",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://*.keka.com/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "KeKo - Keka Check-in/out",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "options_page": "options.html",

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
